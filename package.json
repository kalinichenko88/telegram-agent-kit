{
  "name": "telegram-agent-kit",
  "version": "0.1.0",
  "description": "Render markdown to Telegram, stream agent replies into live drafts, and drive a snapshot/rollback turn-loop — runtime-agnostic.",
  "type": "module",
  "license": "MIT",
  "author": "Ivan Kalinichenko",
  "homepage": "https://github.com/kalinichenko88/telegram-agent-kit#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kalinichenko88/telegram-agent-kit.git"
  },
  "bugs": {
    "url": "https://github.com/kalinichenko88/telegram-agent-kit/issues"
  },
  "keywords": [
    "telegram",
    "telegram-bot",
    "bot-api",
    "llm",
    "agent",
    "agents",
    "streaming",
    "markdown",
    "html",
    "langgraph",
    "deepagents",
    "esm"
  ],
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./deepagents": {
      "types": "./dist/deepagents/index.d.ts",
      "import": "./dist/deepagents/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "peerDependencies": {
    "@langchain/core": ">=1",
    "deepagents": ">=1"
  },
  "peerDependenciesMeta": {
    "@langchain/core": {
      "optional": true
    },
    "deepagents": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.0",
    "@langchain/core": "^1.2.0",
    "@types/node": "^22.0.0",
    "deepagents": "^1.10.5",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
